<style>
:root {
  --navy: #1A2340;
  --navy2: #2C3E6B;
  --blue: #4F6AF5;
  --blue-d: #3752D3;
  --purple: #7C5CFC;
  --gold: #F59E0B;
  --green: #22C55E;
  --coral: #FF6B6B;
  --bg: #F0F4FA;
  --card: #fff;
  --txt: #1A2340;
  --txt2: #64748B;
  --muted: #94A3B8;
  --border: rgba(26,35,64,.09);
}
* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Manrope', sans-serif;
  background: #0D1120;
  color: #fff;
  overflow-x: hidden;
  line-height: 1.6;
}

/* ═══ NOISE OVERLAY ═══ */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 0;
  opacity: .5;
}

/* ═══ NAV ═══ */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  padding: 18px 40px;
  display: flex;
  align-items: center;
  gap: 16px;
  background: rgba(13,17,32,.8);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(255,255,255,.06);
}
.nav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
.nav-logomark {
  width: 36px; height: 36px;
  border-radius: 11px;
  background: linear-gradient(135deg, var(--blue), var(--purple));
  display: flex; align-items: center; justify-content: center;
  font-size: 18px;
  box-shadow: 0 4px 16px rgba(79,106,245,.45);
}
.nav-brand { font-size: 18px; font-weight: 800; color: #fff; }
.nav-brand span { color: #8B9EFF; }
.nav-pill {
  margin-left: 14px;
  font-size: 10.5px; font-weight: 700;
  background: rgba(34,197,94,.12); color: #4ade80;
  border: 1px solid rgba(34,197,94,.25);
  padding: 3px 10px; border-radius: 100px;
  letter-spacing: .5px; text-transform: uppercase;
}
.nav-spacer { flex: 1; }
.nav-cta {
  background: linear-gradient(135deg, var(--blue), var(--purple));
  color: #fff; font-size: 13px; font-weight: 700;
  padding: 9px 22px; border-radius: 100px;
  text-decoration: none; border: none; cursor: pointer;
  box-shadow: 0 4px 18px rgba(79,106,245,.45);
  transition: all .2s;
}
.nav-cta:hover { transform: translateY(-1px); box-shadow: 0 8px 28px rgba(79,106,245,.55); }

/* ═══ HERO ═══ */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120px 24px 80px;
  text-align: center;
  overflow: hidden;
}
.hero-glow-1 {
  position: absolute;
  width: 600px; height: 600px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(79,106,245,.25) 0%, transparent 70%);
  top: -100px; left: -100px;
  pointer-events: none;
  animation: drift1 8s ease-in-out infinite;
}
.hero-glow-2 {
  position: absolute;
  width: 500px; height: 500px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(124,92,252,.2) 0%, transparent 70%);
  bottom: -60px; right: -60px;
  pointer-events: none;
  animation: drift2 10s ease-in-out infinite;
}
.hero-glow-3 {
  position: absolute;
  width: 300px; height: 300px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(245,158,11,.12) 0%, transparent 70%);
  top: 50%; left: 50%; transform: translate(-50%, -50%);
  pointer-events: none;
}
@keyframes drift1 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(40px,30px)} }
@keyframes drift2 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(-30px,20px)} }

.hero-badge {
  display: inline-flex; align-items: center; gap: 7px;
  background: rgba(79,106,245,.12); border: 1px solid rgba(79,106,245,.3);
  color: #A5B4FC; font-size: 12px; font-weight: 700;
  padding: 6px 16px; border-radius: 100px;
  margin-bottom: 28px;
  animation: fadeUp .6s .1s both;
}
.hero-badge-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--green); box-shadow: 0 0 6px var(--green); animation: pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }

.hero-heading {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(42px, 7vw, 80px);
  line-height: 1.08;
  color: #fff;
  margin-bottom: 22px;
  max-width: 820px;
  animation: fadeUp .6s .2s both;
}
.hero-heading em { color: #8B9EFF; font-style: italic; }
.hero-heading .gold { color: var(--gold); }

.hero-sub {
  font-size: clamp(15px, 2vw, 18px);
  color: rgba(255,255,255,.55);
  max-width: 520px;
  margin-bottom: 40px;
  font-weight: 500;
  line-height: 1.7;
  animation: fadeUp .6s .3s both;
}

.hero-btns {
  display: flex; gap: 14px; align-items: center; flex-wrap: wrap; justify-content: center;
  animation: fadeUp .6s .4s both;
}
.btn-hero-primary {
  display: inline-flex; align-items: center; gap: 9px;
  background: linear-gradient(135deg, var(--blue), var(--purple));
  color: #fff; font-size: 15px; font-weight: 700;
  padding: 15px 32px; border-radius: 16px;
  text-decoration: none; border: none; cursor: pointer;
  box-shadow: 0 8px 32px rgba(79,106,245,.5);
  transition: all .25s;
}
.btn-hero-primary:hover { transform: translateY(-3px); box-shadow: 0 14px 40px rgba(79,106,245,.6); }
.btn-hero-secondary {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(255,255,255,.07); color: rgba(255,255,255,.8);
  font-size: 14px; font-weight: 600;
  padding: 14px 28px; border-radius: 16px;
  text-decoration: none; border: 1px solid rgba(255,255,255,.12);
  cursor: pointer; transition: all .22s;
}
.btn-hero-secondary:hover { background: rgba(255,255,255,.12); border-color: rgba(255,255,255,.25); }

@keyframes fadeUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

/* ═══ DEMO CARDS BELOW HERO ═══ */
.demo-strip {
  position: relative; z-index: 2;
  padding: 10px 24px 80px;
  display: flex; justify-content: center; gap: 14px; flex-wrap: wrap;
  animation: fadeUp .6s .5s both;
}
.demo-card {
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 16px;
  padding: 18px 22px;
  display: flex; align-items: center; gap: 14px;
  text-decoration: none; color: inherit;
  cursor: pointer;
  transition: all .22s;
  min-width: 210px;
}
.demo-card:hover {
  background: rgba(255,255,255,.09);
  border-color: rgba(79,106,245,.4);
  transform: translateY(-2px);
}
.demo-card-ico {
  width: 44px; height: 44px;
  border-radius: 13px;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px; flex-shrink: 0;
}
.demo-card-label { font-size: 11px; color: rgba(255,255,255,.4); font-weight: 600; text-transform: uppercase; letter-spacing: .7px; }
.demo-card-title { font-size: 14px; font-weight: 700; color: #fff; margin-top: 2px; }

/* ═══ FEATURES SECTION ═══ */
.section {
  position: relative; z-index: 2;
  padding: 80px 24px;
  max-width: 1100px;
  margin: 0 auto;
}
.sec-label {
  font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 2px;
  color: var(--blue); margin-bottom: 14px;
}
.sec-title {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(32px, 5vw, 52px);
  line-height: 1.15; color: #fff; margin-bottom: 14px;
}
.sec-sub { font-size: 16px; color: rgba(255,255,255,.5); max-width: 520px; font-weight: 500; }

.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 18px;
  margin-top: 50px;
}
.feat-card {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 22px;
  padding: 28px;
  transition: all .25s;
  position: relative;
  overflow: hidden;
}
.feat-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  opacity: 0;
  transition: opacity .25s;
}
.feat-card:hover { background: rgba(255,255,255,.07); border-color: rgba(255,255,255,.14); transform: translateY(-2px); }
.feat-card:hover::before { opacity: 1; }
.feat-card.c1::before { background: linear-gradient(90deg, var(--blue), var(--purple)); }
.feat-card.c2::before { background: linear-gradient(90deg, var(--green), #38F9D7); }
.feat-card.c3::before { background: linear-gradient(90deg, var(--gold), #FBBF24); }
.feat-card.c4::before { background: linear-gradient(90deg, var(--coral), #FF9A9E); }
.feat-card.c5::before { background: linear-gradient(90deg, var(--purple), #B06FFA); }
.feat-card.c6::before { background: linear-gradient(90deg, #14B8A6, #38F9D7); }

.feat-ico {
  width: 50px; height: 50px; border-radius: 15px;
  display: flex; align-items: center; justify-content: center;
  font-size: 24px; margin-bottom: 18px;
}
.feat-title { font-size: 16px; font-weight: 800; color: #fff; margin-bottom: 8px; }
.feat-desc { font-size: 13.5px; color: rgba(255,255,255,.5); line-height: 1.65; font-weight: 500; }

/* ═══ DEMO ROLES SECTION ═══ */
.roles-section {
  position: relative; z-index: 2;
  padding: 60px 24px 100px;
  background: rgba(255,255,255,.02);
  border-top: 1px solid rgba(255,255,255,.06);
  border-bottom: 1px solid rgba(255,255,255,.06);
}
.roles-inner {
  max-width: 900px;
  margin: 0 auto;
  text-align: center;
}
.roles-title {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(28px, 4vw, 44px);
  color: #fff; margin-bottom: 12px;
}
.roles-sub { font-size: 15px; color: rgba(255,255,255,.45); margin-bottom: 48px; font-weight: 500; }

.roles-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 18px;
  max-width: 660px; margin: 0 auto 40px;
}
.role-card {
  background: rgba(255,255,255,.05);
  border: 1.5px solid rgba(255,255,255,.1);
  border-radius: 22px;
  padding: 28px 24px;
  text-align: left;
  transition: all .25s;
  cursor: pointer;
  text-decoration: none; color: inherit;
  display: block;
}
.role-card:hover { transform: translateY(-4px); }
.role-card.admin { border-color: rgba(255,107,107,.3); background: rgba(255,107,107,.06); }
.role-card.admin:hover { border-color: rgba(255,107,107,.6); box-shadow: 0 12px 40px rgba(255,107,107,.15); }
.role-card.employee { border-color: rgba(79,106,245,.3); background: rgba(79,106,245,.06); }
.role-card.employee:hover { border-color: rgba(79,106,245,.6); box-shadow: 0 12px 40px rgba(79,106,245,.15); }
.role-ico { font-size: 36px; margin-bottom: 14px; }
.role-name { font-size: 18px; font-weight: 800; color: #fff; margin-bottom: 4px; }
.role-desc { font-size: 12.5px; color: rgba(255,255,255,.45); margin-bottom: 14px; font-weight: 500; line-height: 1.5; }
.role-email { font-size: 11.5px; font-weight: 700; padding: 4px 11px; border-radius: 100px; display: inline-block; }
.role-card.admin .role-email { background: rgba(255,107,107,.15); color: #FFB3B3; }
.role-card.employee .role-email { background: rgba(79,106,245,.2); color: #A5B4FC; }
.role-feats { margin-top: 16px; display: flex; flex-direction: column; gap: 6px; }
.role-feat { display: flex; align-items: center; gap: 8px; font-size: 12px; color: rgba(255,255,255,.55); font-weight: 500; }
.role-feat-dot { width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; }

.big-cta {
  display: inline-flex; align-items: center; gap: 10px;
  background: linear-gradient(135deg, var(--blue), var(--purple));
  color: #fff; font-size: 16px; font-weight: 800;
  padding: 18px 42px; border-radius: 18px;
  text-decoration: none; border: none; cursor: pointer;
  box-shadow: 0 10px 40px rgba(79,106,245,.55);
  transition: all .25s;
}
.big-cta:hover { transform: translateY(-3px); box-shadow: 0 16px 50px rgba(79,106,245,.65); }

/* ═══ STATS ═══ */
.stats-bar {
  position: relative; z-index: 2;
  padding: 60px 24px;
  border-bottom: 1px solid rgba(255,255,255,.06);
}
.stats-inner {
  max-width: 900px; margin: 0 auto;
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px;
  text-align: center;
}
.stat-val {
  font-family: 'DM Serif Display', serif;
  font-size: 40px; color: #fff; line-height: 1;
}
.stat-label { font-size: 13px; color: rgba(255,255,255,.4); font-weight: 600; margin-top: 6px; }
.stat-accent { color: var(--blue); }

/* ═══ FOOTER ═══ */
footer {
  position: relative; z-index: 2;
  padding: 40px 40px;
  display: flex; align-items: center; gap: 20px;
  border-top: 1px solid rgba(255,255,255,.06);
  flex-wrap: wrap;
}
.footer-logo { display: flex; align-items: center; gap: 8px; }
.footer-brand { font-size: 15px; font-weight: 800; color: rgba(255,255,255,.6); }
.footer-brand span { color: #8B9EFF; }
.footer-copy { font-size: 12px; color: rgba(255,255,255,.25); font-weight: 500; }
.footer-links { display: flex; gap: 20px; margin-left: auto; }
.footer-links a { font-size: 12px; color: rgba(255,255,255,.3); font-weight: 600; text-decoration: none; }
.footer-links a:hover { color: rgba(255,255,255,.7); }

/* ═══ RESPONSIVE ═══ */
@media (max-width: 600px) {
  nav { padding: 14px 18px; }
  .roles-grid { grid-template-columns: 1fr; }
  .stats-inner { grid-template-columns: repeat(2,1fr); }
  .footer-links { display: none; }
}
</style>
</head>
